DATABASE_URL=postgresql+asyncpg://loguser:logpassword@localhost:5433/loganalyser
DEBUG=True
APP_NAME=Ops Agent
API_V1_PREFIX=/api/v1
MAX_MESSAGE_PREVIEW_LENGTH=500
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
LOG_LEVEL=INFO

# ── OpenCode server settings ─────────────────────────────────────────
# Leave OPENCODE_SERVER_URL empty to use the mock analyzer.
#
# Local development (run `opencode serve --port 4096` yourself):
#   OPENCODE_SERVER_URL=http://localhost:4096
#
# Docker Compose (automatic — api talks to the opencode sidecar):
#   OPENCODE_SERVER_URL=http://opencode:4096   (set in docker-compose.yml)
OPENCODE_SERVER_URL=http://localhost:8001
# OPENCODE_PROVIDER_ID=anthropic              # Provider configured in OpenCode
# OPENCODE_MODEL_ID=claude-sonnet-4-20250514  # Model to use for analysis
# OPENCODE_SERVER_PASSWORD=                   # Optional basic-auth password
# OPENCODE_SERVER_USERNAME=opencode           # Optional basic-auth username
OPENCODE_TIMEOUT=60.0

# ── LLM provider API keys (used by the OpenCode container) ───────────
# Set the key for whichever provider you configured in OpenCode.
# Only one is required — pick your provider.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
